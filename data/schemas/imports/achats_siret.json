{
  "$schema": "https://frictionlessdata.io/schemas/table-schema.json",
  "encoding": "utf-8",
  "fields": [
    {
      "constraints": {
        "required": true
      },
      "description": "L'établissement avec ce SIRET doit être déjà enregistré sur notre plateforme.",
      "example": "49463556926130",
      "format": "default",
      "name": "siret",
      "title": "SIRET de l'établissement ayant réalisé l'achat",
      "type": "any"
    },
    {
      "constraints": {
        "required": true
      },
      "description": "",
      "example": "Pommes de terre",
      "format": "default",
      "name": "description",
      "title": "Description de l'achat",
      "type": "string"
    },
    {
      "constraints": {
        "required": true
      },
      "description": "",
      "example": "Le traiteur du village",
      "format": "default",
      "name": "fournisseur",
      "title": "Nom du fournisseur",
      "type": "string"
    },
    {
      "constraints": {
        "required": true
      },
      "description": "",
      "example": "2022-01-30",
      "format": "%Y-%m-%d",
      "name": "date",
      "title": "Date de l'achat",
      "type": "date"
    },
    {
      "constraints": {
        "required": true
      },
      "description": "Utiliser le point comme séparateur décimal",
      "example": "1234.99",
      "name": "prix_ht",
      "title": "Prix HT de l'achat",
      "type": "number"
    },
    {
      "constraints": {
        "pattern": "^ *(VIANDES_VOLAILLES|CHARCUTERIE|PRODUITS_DE_LA_MER|FRUITS_ET_LEGUMES|PRODUITS_LAITIERS|BOULANGERIE|BOISSONS|AUTRES) *$",
        "required": true
      },
      "description": "",
      "doc_enum": [
        "VIANDES_VOLAILLES",
        "CHARCUTERIE",
        "PRODUITS_DE_LA_MER",
        "FRUITS_ET_LEGUMES",
        "PRODUITS_LAITIERS",
        "BOULANGERIE",
        "BOISSONS",
        "AUTRES"
      ],
      "example": "VIANDES_VOLAILLES",
      "format": "default",
      "name": "famille_produits",
      "title": "Famille de produits de l'achat",
      "type": "string"
    },
    {
      "constraints": {
        "pattern": "^ *(BIO|LABEL_ROUGE|AOCAOP|IGP|STG|HVE|PECHE_DURABLE|RUP|COMMERCE_EQUITABLE|FERMIER|EXTERNALITES|PERFORMANCE)( *, *(BIO|LABEL_ROUGE|AOCAOP|IGP|STG|HVE|PECHE_DURABLE|RUP|COMMERCE_EQUITABLE|FERMIER|EXTERNALITES|PERFORMANCE))* *$",
        "required": false
      },
      "description": "",
      "doc_enum": [
        "BIO",
        "LABEL_ROUGE",
        "AOCAOP",
        "IGP",
        "STG",
        "HVE",
        "PECHE_DURABLE",
        "RUP",
        "COMMERCE_EQUITABLE",
        "FERMIER",
        "EXTERNALITES",
        "PERFORMANCE"
      ],
      "doc_enum_multiple": true,
      "doc_enum_multiple_seperator": ",",
      "example": "BIO,IGP",
      "format": "default",
      "name": "categories_egalim",
      "title": "Catégories EGalim",
      "type": "string"
    },
    {
      "constraints": {
        "pattern": "^ *(EUROPE|FRANCE) *$",
        "required": false
      },
      "description": "Une seule origine peut être renseignée, EUROPE (hors France) ou FRANCE",
      "doc_enum": [
        "EUROPE",
        "FRANCE"
      ],
      "example": "FRANCE",
      "format": "default",
      "name": "origine",
      "title": "Origine",
      "type": "string"
    },
    {
      "constraints": {
        "required": false
      },
      "description": "Si la cellule contient une des valeurs acceptées, le champ sera considéré comme 'oui', sinon le champ sera considéré comme 'non'",
      "doc_enum": [
        "OUI",
        "x"
      ],
      "example": "OUI",
      "falseValues": [
        "non",
        "NON",
        ""
      ],
      "format": "default",
      "name": "est_circuit_court",
      "title": "Circuit court",
      "trueValues": [
        "OUI",
        "oui",
        "x"
      ],
      "type": "boolean"
    },
    {
      "constraints": {
        "required": false
      },
      "description": "Si la cellule contient une des valeurs acceptées, le champ sera considéré comme 'oui', sinon le champ sera considéré comme 'non'",
      "doc_enum": [
        "OUI",
        "x"
      ],
      "example": "OUI",
      "falseValues": [
        "non",
        "NON",
        ""
      ],
      "format": "default",
      "name": "est_local",
      "title": "Local ou de proximité",
      "trueValues": [
        "OUI",
        "oui",
        "x"
      ],
      "type": "boolean"
    },
    {
      "constraints": {
        "pattern": "^ *(PAT|COMMUNE|DEPARTEMENT|REGION|KM) *$",
        "required": false
      },
      "description": "Facultatif. Seulement si l'achat est renseigné comme 'est_local'",
      "doc_enum": [
        "PAT",
        "COMMUNE",
        "DEPARTEMENT",
        "REGION",
        "KM"
      ],
      "example": "PAT",
      "format": "default",
      "name": "definition_local",
      "title": "Définition de local",
      "type": "string"
    },
    {
      "constraints": {
        "required": false
      },
      "description": "Facultatif. Seulement si l'achat est renseigné comme 'est_local' et que la définition de local est 'KM'",
      "example": "50",
      "format": "default",
      "name": "definition_local_km",
      "title": "Distance en kilomètres",
      "type": "number"
    }
  ],
  "homepage": "https://github.com/betagouv/ma-cantine",
  "name": "import-achats-siret",
  "path": "https://raw.githubusercontent.com/betagouv/ma-cantine/refs/heads/main/data/schemas/imports/achats_siret.json",
  "title": "Schema import des achats via le SIRET de la cantine"
}
